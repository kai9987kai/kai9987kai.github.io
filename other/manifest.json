{
  "manifest_version": 3,
  "name": "Star Wars Nuggets Search Tool",
  "short_name": "SW Nuggets",
  "version": "1.0.0",
  "description": "A fast Chrome extension for searching Star Wars Nuggets videos, YouTube, Google, and Star Wars references.",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Search Star Wars Nuggets",
    "default_popup": "extension.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "omnibox": {
    "keyword": "swn"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Star Wars Nuggets Search Tool"
    }
  }
}
