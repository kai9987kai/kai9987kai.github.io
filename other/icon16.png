<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 540" role="img" aria-labelledby="title desc">
  <title id="title">Star Wars Nuggets fan art</title>
  <desc id="desc">A golden nugget shaped starship flying through a sci-fi star field with orange engine glow.</desc>
  <defs>
    <radialGradient id="space" cx="50%" cy="44%" r="70%">
      <stop offset="0" stop-color="#22294a"/>
      <stop offset="0.45" stop-color="#0a1021"/>
      <stop offset="1" stop-color="#020205"/>
    </radialGradient>
    <linearGradient id="nugget" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0" stop-color="#ffd26f"/>
      <stop offset="0.45" stop-color="#f5a51b"/>
      <stop offset="1" stop-color="#8f4b00"/>
    </linearGradient>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="12" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  <rect width="900" height="540" fill="url(#space)"/>
  <g opacity="0.8">
    <circle cx="74" cy="74" r="2" fill="#fff"/>
    <circle cx="194" cy="114" r="1.3" fill="#ffd26f"/>
    <circle cx="322" cy="62" r="2.2" fill="#fff"/>
    <circle cx="790" cy="96" r="1.8" fill="#fff"/>
    <circle cx="842" cy="194" r="1.3" fill="#ffd26f"/>
    <circle cx="640" cy="408" r="2" fill="#fff"/>
    <circle cx="112" cy="410" r="1.5" fill="#fff"/>
    <circle cx="706" cy="258" r="1.6" fill="#ffd26f"/>
    <circle cx="406" cy="466" r="1.8" fill="#fff"/>
  </g>
  <path d="M0 298 C160 224 230 220 390 232" stroke="#ffb000" stroke-width="4" opacity="0.18" fill="none"/>
  <path d="M0 336 C160 282 248 278 420 286" stroke="#ff4d1d" stroke-width="3" opacity="0.18" fill="none"/>
  <g transform="translate(280 164) rotate(-12)">
    <ellipse cx="130" cy="130" rx="210" ry="78" fill="#ff4d1d" opacity="0.22" filter="url(#glow)"/>
    <path d="M78 110 C114 50 214 36 294 80 C372 124 392 210 330 248 C248 300 114 278 58 206 C30 170 44 135 78 110Z" fill="url(#nugget)" stroke="#ffe2a1" stroke-width="8"/>
    <path d="M132 98 C170 72 250 80 284 114 C314 144 302 182 260 196 C198 216 126 196 104 158 C92 136 100 116 132 98Z" fill="#ffd777" opacity="0.52"/>
    <circle cx="165" cy="143" r="12" fill="#4c2500" opacity="0.32"/>
    <circle cx="242" cy="176" r="15" fill="#4c2500" opacity="0.25"/>
    <path d="M58 190 L-54 240" stroke="#ff7b2a" stroke-width="22" stroke-linecap="round" filter="url(#glow)"/>
    <path d="M66 208 L-22 294" stroke="#ffd26f" stroke-width="11" stroke-linecap="round" opacity="0.85"/>
  </g>
  <text x="54" y="486" fill="#ffe2a1" font-family="Arial, Helvetica, sans-serif" font-size="42" font-weight="800" letter-spacing="2">STAR WARS NUGGETS</text>
  <text x="58" y="514" fill="#b8b1a2" font-family="Arial, Helvetica, sans-serif" font-size="18">search faster than lightspeed</text>
</svg>
